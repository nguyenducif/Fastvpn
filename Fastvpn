<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>FASTVPN.IO.VN</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ===== RESET ===== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #0c0e1a;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 12px;
      color: #fff;
      position: relative;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ===== NỀN ĐƠN GIẢN ===== */
    .bg-glow {
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.15;
      pointer-events: none;
      z-index: 0;
    }
    .bg-glow-1 {
      width: 250px;
      height: 250px;
      background: #6d5dfb;
      top: -60px;
      left: -80px;
    }
    .bg-glow-2 {
      width: 300px;
      height: 300px;
      background: #00d4ff;
      bottom: -80px;
      right: -80px;
    }

    /* ===== CONTAINER CHÍNH ===== */
    .container {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 420px;
      background: rgba(20, 24, 44, 0.7);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: 28px;
      padding: 24px 20px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
      animation: fadeUp 0.5s ease;
    }

    @keyframes fadeUp {
      0% { opacity: 0; transform: translateY(16px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    /* ===== BRAND ===== */
    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 16px;
    }

    .brand-icon {
      font-size: 28px;
      background: linear-gradient(135deg, #6d5dfb, #00d4ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .brand h1 {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, #fff, #b5c9ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .brand .badge {
      font-size: 10px;
      font-weight: 600;
      background: rgba(109, 93, 251, 0.2);
      padding: 3px 10px;
      border-radius: 20px;
      color: #b5c9ff;
      margin-left: auto;
      white-space: nowrap;
      letter-spacing: 0.3px;
    }

    /* ===== TAGLINE ===== */
    .tagline {
      font-size: 14px;
      color: #9aa9d6;
      margin-bottom: 20px;
      padding-left: 12px;
      border-left: 3px solid #6d5dfb;
      line-height: 1.4;
      font-weight: 400;
    }

    /* ===== CARD GRID (1 cột trên mobile) ===== */
    .card-grid {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .card {
      background: rgba(255, 255, 255, 0.04);
      border-radius: 20px;
      padding: 18px 16px;
      border: 1px solid rgba(255, 255, 255, 0.05);
      cursor: pointer;
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      gap: 14px;
      position: relative;
      overflow: hidden;
      -webkit-tap-highlight-color: transparent;
    }

    .card:active {
      transform: scale(0.97);
      background: rgba(255, 255, 255, 0.07);
    }

    .card-icon {
      font-size: 28px;
      min-width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(109, 93, 251, 0.15);
      border-radius: 14px;
      color: #6d5dfb;
    }

    .card-content {
      flex: 1;
      min-width: 0;
    }

    .card-content h3 {
      font-size: 16px;
      font-weight: 600;
      color: #f0f4ff;
      margin-bottom: 2px;
    }

    .card-content p {
      font-size: 12px;
      color: #8a9ac4;
      line-height: 1.3;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .card-arrow {
      color: #5a6b94;
      font-size: 14px;
      transition: transform 0.2s ease;
      min-width: 20px;
      text-align: center;
    }

    .card:active .card-arrow {
      transform: translateX(4px);
    }

    /* ===== FOOTER ===== */
    .footer-note {
      margin-top: 20px;
      text-align: center;
      font-size: 11px;
      color: #3d4a6b;
      letter-spacing: 0.3px;
      padding-top: 16px;
      border-top: 1px solid rgba(255, 255, 255, 0.04);
    }

    .footer-note i {
      color: #6d5dfb;
      margin: 0 3px;
    }

    /* ===== WIDGET HỖ TRỢ (tối ưu mobile) ===== */
    .support-widget {
      position: fixed;
      bottom: 20px;
      right: 16px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 10px;
    }

    .main-wrapper {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 10px;
    }

    .support-btn {
      width: 50px;
      height: 50px;
      background: #2a3344;
      border-radius: 50%;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 22px;
      cursor: pointer;
      border: none;
      outline: none;
      flex-shrink: 0;
      transition: transform 0.15s ease;
      -webkit-tap-highlight-color: transparent;
    }
    .support-btn:active {
      transform: scale(0.92);
    }

    .status-bubble {
      background: #121212;
      color: #fff;
      padding: 6px 12px 6px 14px;
      border-radius: 30px;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 500;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      white-space: nowrap;
    }
    .status-bubble.hidden {
      opacity: 0;
      transform: scaleX(0);
      pointer-events: none;
      margin-right: -8px;
      overflow: hidden;
      padding: 0;
    }

    .typing-dots {
      display: flex;
      gap: 3px;
      align-items: center;
    }
    .typing-dots span {
      width: 4px;
      height: 4px;
      background: #00d26a;
      border-radius: 50%;
      display: inline-block;
      animation: dot-bounce 1.4s infinite ease-in-out both;
    }
    .typing-dots span:nth-child(1) { animation-delay: -0.32s; }
    .typing-dots span:nth-child(2) { animation-delay: -0.16s; }

    @keyframes dot-bounce {
      0%, 80%, 100% { transform: scale(0); }
      40% { transform: scale(1); }
    }

    .close-bubble {
      color: #666;
      font-size: 11px;
      cursor: pointer;
      background: transparent;
      border: none;
      padding: 2px 4px;
      display: flex;
      align-items: center;
    }
    .close-bubble:hover { color: #fff; }

    /* ===== POPUP MENU ===== */
    .zalo-popup {
      position: absolute;
      bottom: 62px;
      right: 0;
      background: #1a1e2f;
      border-radius: 14px;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
      padding: 6px 0;
      min-width: 170px;
      transform-origin: bottom right;
      transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.2, 0.9, 0.3, 1.2);
      opacity: 0;
      transform: scale(0.9) translateY(8px);
      pointer-events: none;
      visibility: hidden;
      border: 1px solid rgba(255, 255, 255, 0.06);
    }
    .zalo-popup.show {
      opacity: 1;
      transform: scale(1) translateY(0);
      pointer-events: auto;
      visibility: visible;
    }

    .zalo-popup-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 16px;
      text-decoration: none;
      color: #e0e6f0;
      font-weight: 500;
      font-size: 14px;
      transition: background 0.15s ease;
      cursor: pointer;
    }
    .zalo-popup-item:active {
      background: rgba(255, 255, 255, 0.06);
    }
    .zalo-popup-item i {
      width: 20px;
      font-size: 16px;
      color: #6d5dfb;
      text-align: center;
    }
    .zalo-popup-item .label small {
      font-weight: 400;
      font-size: 10px;
      opacity: 0.5;
      display: block;
      margin-top: 1px;
    }
    .zalo-popup-divider {
      height: 1px;
      background: rgba(255, 255, 255, 0.06);
      margin: 0 14px;
    }

    /* ===== TOAST ===== */
    .toast {
      position: fixed;
      bottom: 80px;
      left: 50%;
      transform: translateX(-50%) translateY(60px);
      background: rgba(20, 24, 44, 0.95);
      backdrop-filter: blur(12px);
      padding: 8px 20px;
      border-radius: 30px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      color: #d6e0ff;
      font-size: 13px;
      font-weight: 500;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
      transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      opacity: 0;
      visibility: hidden;
      z-index: 999;
      display: flex;
      align-items: center;
      gap: 8px;
      white-space: nowrap;
      pointer-events: none;
    }
    .toast.show {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }
    .toast i {
      color: #6d5dfb;
      font-size: 14px;
    }

    /* ===== RESPONSIVE ===== */
    @media (min-width: 600px) {
      .container {
        max-width: 500px;
        padding: 32px 28px;
        border-radius: 36px;
      }
      .brand h1 { font-size: 28px; }
      .card-grid { gap: 16px; }
      .card { padding: 20px 20px; }
      .card-content h3 { font-size: 18px; }
      .card-content p { font-size: 14px; }
      .support-btn {
        width: 56px;
        height: 56px;
        font-size: 24px;
      }
      .bg-glow-1 { width: 350px; height: 350px; }
      .bg-glow-2 { width: 400px; height: 400px; }
    }

    @media (max-width: 380px) {
      .container { padding: 16px 14px; }
      .brand h1 { font-size: 18px; }
      .brand-icon { font-size: 22px; }
      .card { padding: 14px 12px; gap: 10px; }
      .card-icon { font-size: 22px; min-width: 36px; height: 36px; }
      .card-content h3 { font-size: 14px; }
      .card-content p { font-size: 11px; }
      .support-btn { width: 44px; height: 44px; font-size: 18px; }
      .status-bubble { font-size: 10px; padding: 4px 10px; }
    }
  </style>
</head>
<body>

  <!-- ===== NỀN ===== -->
  <div class="bg-glow bg-glow-1"></div>
  <div class="bg-glow bg-glow-2"></div>

  <!-- ===== TOAST ===== -->
  <div id="toast" class="toast">
    <i class="fas fa-check-circle"></i>
    <span id="toastMessage">Đã sao chép!</span>
  </div>

  <!-- ===== CONTAINER CHÍNH ===== -->
  <div class="container">
    <!-- Brand -->
    <div class="brand">
      <i class="fas fa-shield-alt brand-icon"></i>
      <h1>FASTVPN.IO.VN</h1>
      <span class="badge"><i class="fas fa-bolt" style="margin-right: 4px;"></i>Secure</span>
    </div>

    <div class="tagline">
      <i class="fas fa-globe" style="margin-right: 8px; color: #6d5dfb;"></i>
      Kết nối an toàn · Tốc độ cao · Bảo mật tối đa
    </div>

    <!-- 2 Cards -->
    <div class="card-grid">
      <!-- Card 1 -->
      <div class="card" id="goToWebsite">
        <div class="card-icon"><i class="fas fa-shopping-cart"></i></div>
        <div class="card-content">
          <h3>Truy cập web mua gói</h3>
          <p>Đến fastvpn.io.vn mua gói VPN tốc độ cao</p>
        </div>
        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
      </div>

      <!-- Card 2 -->
      <div class="card" id="getAppleId">
        <div class="card-icon"><i class="fab fa-apple"></i></div>
        <div class="card-content">
          <h3>Lấy ID APPLE</h3>
          <p>Lấy ID dùng thử Shadowrocket từ DVSTEAM.VN</p>
        </div>
        <div class="card-arrow"><i class="fas fa-chevron-right"></i></div>
      </div>
    </div>

    <div class="footer-note">
      <i class="fas fa-lock"></i> Bảo mật · <i class="fas fa-bolt"></i> Tốc độ cao · <i class="fas fa-infinity"></i> Không giới hạn
    </div>
  </div>

  <!-- ===== WIDGET HỖ TRỢ ===== -->
  <div class="support-widget" id="supportWidget">
    <div class="zalo-popup" id="zaloPopup">
      <a href="https://zalo.me/0383530002" target="_blank" rel="noopener" class="zalo-popup-item">
        <i class="fas fa-user-tie"></i>
        <span class="label">Admin</span>
      </a>
      <div class="zalo-popup-divider"></div>
      <a href="https://zalo.me/g/qclbuyfoecyurr5krsmi" target="_blank" rel="noopener" class="zalo-popup-item">
        <i class="fas fa-users"></i>
        <span class="label">Cộng đồng <small>Nhóm Zalo</small></span>
      </a>
    </div>

    <div class="main-wrapper">
      <div class="status-bubble" id="statusBubble">
        <span>Online 24/7</span>
        <div class="typing-dots">
          <span></span><span></span><span></span>
        </div>
        <button class="close-bubble" id="closeBubbleBtn">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <button class="support-btn" id="supportBtn">
        <i class="fas fa-headset"></i>
      </button>
    </div>
  </div>

  <!-- ===== JAVASCRIPT ===== -->
  <script>
    (function() {
      "use strict";

      // DOM
      const goToWebsite = document.getElementById('goToWebsite');
      const getAppleId = document.getElementById('getAppleId');
      const toast = document.getElementById('toast');
      const toastMsg = document.getElementById('toastMessage');

      // Card 1
      goToWebsite.addEventListener('click', function() {
        window.open('https://fastvpn.io.vn', '_blank');
        showToast('Đang mở fastvpn.io.vn ...');
      });

      // Card 2
      getAppleId.addEventListener('click', function() {
        window.open('https://dvsteam.vn/id-apple-shadowrocket', '_blank');
        showToast('Đang mở trang ID Apple ...');
      });

      // Toast
      let timer = null;
      function showToast(msg) {
        toastMsg.textContent = msg;
        toast.classList.add('show');
        clearTimeout(timer);
        timer = setTimeout(() => toast.classList.remove('show'), 2200);
      }

      // ===== WIDGET HỖ TRỢ =====
      const mainBtn = document.getElementById('supportBtn');
      const popup = document.getElementById('zaloPopup');
      const bubble = document.getElementById('statusBubble');
      const closeBubble = document.getElementById('closeBubbleBtn');
      let isOpen = false;

      closeBubble.addEventListener('click', function(e) {
        e.stopPropagation();
        bubble.classList.add('hidden');
      });

      mainBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        isOpen = !isOpen;
        popup.classList.toggle('show', isOpen);
      });

      document.addEventListener('click', function(e) {
        if (isOpen) {
          const target = e.target;
          if (!popup.contains(target) && !mainBtn.contains(target)) {
            isOpen = false;
            popup.classList.remove('show');
          }
        }
      });

      // Đóng popup khi chọn item
      document.querySelectorAll('.zalo-popup-item').forEach(item => {
        item.addEventListener('click', function() {
          setTimeout(() => {
            isOpen = false;
            popup.classList.remove('show');
          }, 150);
        });
      });

      console.log('FASTVPN.IO.VN · Mobile optimized');
    })();
  </script>

</body>
</html>
